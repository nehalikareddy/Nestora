<% layout("/layouts/boilerplate") %>

<style>
  /* ====== FILTER STYLING ====== */
  #filters {
    display: flex;
    flex-wrap: nowrap; /* keep filters + toggle on one line */
    align-items: center;
    justify-content: space-between; /* toggle goes right */
    margin-top: 1rem;
    margin-bottom: 0.5rem;
    overflow-x: auto; /* enable horizontal scroll if needed */
    white-space: nowrap;
    scrollbar-width: thin; /* for Firefox */
    scrollbar-color: #cfcfcf transparent; /* light scrollbar */
    scroll-behavior: smooth; /* smooth horizontal scroll */
  }

  /* ===== Chrome/Safari scrollbar styling ===== */
  #filters::-webkit-scrollbar {
    height: 6px; /* thin scrollbar */
  }

  #filters::-webkit-scrollbar-thumb {
    background-color: #bdbdbd; /* light gray thumb */
    border-radius: 10px;
    transition: background-color 0.3s ease;
  }

  #filters::-webkit-scrollbar-thumb:hover {
    background-color: #999; /* darker when hovered */
  }

  #filters::-webkit-scrollbar-track {
    background: transparent;
  }

  /* Hide scrollbar until user interacts */
  #filters::-webkit-scrollbar {
    opacity: 0;
  }
  #filters:hover::-webkit-scrollbar {
    opacity: 1;
  }

  /* ====== FILTER ICONS ====== */
  .filter {
    text-align: center;
    margin-right: 2rem;
    margin-top: 1rem;
    opacity: 0.75;
    transition: 0.2s ease;
    flex-shrink: 0; /* prevent filters from shrinking */
  }

  .filter:hover {
    opacity: 1;
    cursor: pointer;
  }

  .filter i {
    font-size: 1.1rem;
    color: #555;
  }

  .filter:hover i {
    color: #000;
  }

  .filter p {
    font-size: 0.8rem;
    margin: 0;
  }

  #filters a {
    text-decoration: none;
    color: inherit;
  }

  /* ====== TAX TOGGLE ====== */
  .tax-info {
    display: none;
  }

  .tax-toggle {
    border: 1px solid #000;
    border-radius: 1rem;
    height: 3rem;
    padding: 0 1rem;
    display: flex;
    align-items: center;
    flex-shrink: 0; /* keeps it visible */
    white-space: nowrap;
    background-color: #fff;
    
  }

  .tax-toggle:hover {
    background-color: #f8f9fa;
  }

  /* ====== RESPONSIVE ====== */
  @media (max-width: 992px) {
    #filters {
      justify-content: flex-start;
    }

    .tax-toggle {
      margin-left: auto;
      margin-top: 0;
    }
  }
</style>


<div id="filters">
  <div class="d-flex flex-nowrap align-items-center justify-content-between w-100">

    <div class="d-flex flex-nowrap align-items-center overflow-auto">
      <a href="/listings?category=Trending" class="filter">
        <div><i class="fa-solid fa-fire"></i></div>
        <p>Trending</p>
      </a>
      <a href="/listings?category=Rooms" class="filter">
        <div><i class="fa-solid fa-bed"></i></div>
        <p>Rooms</p>
      </a>
      <a href="/listings?category=Iconic cities" class="filter">
        <div><i class="fa-solid fa-city"></i></div>
        <p>Iconic cities</p>
      </a>
      <a href="/listings?category=Mountains" class="filter">
        <div><i class="fa-solid fa-mountain-city"></i></div>
        <p>Mountains</p>
      </a>
      <a href="/listings?category=Castles" class="filter">
        <div><i class="fa-solid fa-crown"></i></div>
        <p>Castles</p>
      </a>
      <a href="/listings?category=Camping" class="filter">
        <div><i class="fa-solid fa-campground"></i></div>
        <p>Camping</p>
      </a>
      <a href="/listings?category=Farms" class="filter">
        <div><i class="fa-solid fa-cow"></i></div>
        <p>Farms</p>
      </a>
      <a href="/listings?category=Amazing pools" class="filter">
        <div><i class="fa-solid fa-person-swimming"></i></div>
        <p>Amazing pools</p>
      </a>
      <a href="/listings?category=Arctic" class="filter">
        <div><i class="fa-regular fa-snowflake"></i></div>
        <p>Arctic</p>
      </a>
      <a href="/listings?category=beachfront" class="filter">
        <div><i class="fa-solid fa-umbrella-beach"></i></div>
        <p>Beachfront</p>
      </a>
      <a href="/listings?category=Tiny homes" class="filter">
        <div><i class="fa-solid fa-house- chimney"></i></div>
        <p>Tiny homes</p>
      </a>
      <a href="/listings?category=Lakefront" class="filter">
        <div><i class="fa-solid fa-water"></i></div>
        <p>Lakefront</p>
      </a>
    </div>

    <div class="tax-toggle ms-3">
      <div class="form-check-reverse form-switch m-0">
        <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault" />
        <label class="form-check-label" for="switchCheckDefault">Display total after Taxes</label>
      </div>
    </div>

  </div>
</div>
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
  <% for(let listing of allListings){ %>
    <a href="/listings/<%= listing._id %>" class="listing-link text-decoration-none text-dark">
      <div class="card col listing-card border-0 shadow-sm">
        <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height:20rem; object-fit:cover;">
        <div class="card-img-overlay"></div>
        <div class="card-body">
          <p class="card-text">
            <b><%= listing.title %></b><br/>
            ₹<%= listing && typeof listing.price === "number" ? listing.price.toLocaleString("en-IN") : "0" %>/night
            <i class="tax-info">&nbsp;+18% GST</i>
          </p>
        </div>
      </div>
    </a>
  <% } %>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const taxSwitch = document.getElementById("switchCheckDefault");
    const taxInfo = document.getElementsByClassName("tax-info");

    taxSwitch.addEventListener("change", () => {
      for (const info of taxInfo) {
        info.style.display = taxSwitch.checked ? "inline" : "none";
      }
    });
  });
</script>